                        text += '🔫🔫 轮到你了。';
                    }
                } else if (data.length === 0) {
                    if (activeMode === 'hell') {
                        text += '\n\n👻👻 奇迹？BUG？';
                    } else {
                        text += '\n\n🎉🎉 Bot打完了所有子弹，平局！';
