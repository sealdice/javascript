                    // 其他模式：普通空枪逻辑
                    text = '🔫🔫 第' + currentShot + '枪，空枪。\n剩余 ' + data.length + ' 发。';
                    
                    // 判断游戏是否自然结束（弹夹打空）
                    if (data.length === 0) {
