        ext.storageSet('roulette_active_mode_' + msg.groupId, 'egg');
        
        var replyText = '🎲🎲 彩蛋模式已激活，全空概率：' + probability + '%\n';
        if (probability === 0) {
            replyText += '💀💀 相当于经典模式 (1实弹)';
        } else if (probability === 100) {
