            var prob = parseInt(ext.storageGet('roulette_probability_' + msg.groupId) || '10');
            text = '🎲🎲 已切换至【彩蛋模式】\n游戏已重置，当前全空概率：' + prob + '%';
        }
        
        text += '\n\n输入 `.开枪` 开始新游戏。';
